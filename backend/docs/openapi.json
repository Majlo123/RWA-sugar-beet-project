{
  "openapi": "3.0.0",
  "info": {
    "title": "Sugar Beet Token API",
    "version": "1.1.0",
    "description": "API za upravljanje investicijama u šećernu repu, korisnicima i KYC procesom"
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "KYCStatus": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": ["none", "pending", "verified", "rejected"]
          },
          "fullName": { "type": "string" },
          "documentType": { "type": "string", "enum": ["id_card", "passport"] },
          "documentNumber": { "type": "string" },
          "dateOfBirth": { "type": "string" },
          "country": { "type": "string" },
          "hasDocument": { "type": "boolean" },
          "submittedAt": { "type": "string", "format": "date-time" },
          "reviewedAt": { "type": "string", "format": "date-time" },
          "rejectionReason": { "type": "string" }
        }
      }
    }
  },
  "security": [
    { "bearerAuth": [] }
  ],
  "servers": [
    { "url": "http://localhost:5000" }
  ],
  "paths": {
    "/auth/register": {
      "post": {
        "summary": "Registruje novog korisnika",
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": { "type": "string", "example": "investitor1" },
                  "password": { "type": "string", "example": "lozinka123" },
                  "ethAddress": { "type": "string", "example": "0x... adresa novog naloga" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Korisnik uspešno registrovan." },
          "400": { "description": "Korisničko ime je zauzeto ili su podaci neispravni." }
        }
      }
    },
    "/auth/login": {
      "post": {
        "summary": "Prijavljuje postojećeg korisnika",
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": { "type": "string", "example": "investitor1" },
                  "password": { "type": "string", "example": "lozinka123" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Uspešna prijava, vraća JWT token." },
          "400": { "description": "Pogrešni podaci." }
        }
      }
    },
    "/token-price": {
      "get": {
        "summary": "Vraća cenu jednog tokena u USD",
        "tags": ["Treasury"],
        "description": "Očitava javnu konstantu TOKEN_PRICE_USD sa pametnog ugovora.",
        "responses": {
          "200": {
            "description": "Uspešan odgovor sa cenom tokena.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "tokenPriceUSD": { "type": "string", "example": "1000" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/record-investment": {
      "post": {
        "summary": "Evidentira novu investiciju (samo za admina)",
        "tags": ["Treasury"],
        "description": "Poziva recordInvestment funkciju na pametnom ugovoru. Investitor mora imati KYC status 'verified'.",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "investorAddress": {
                    "type": "string",
                    "description": "Ethereum adresa investitora.",
                    "example": "0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266"
                  },
                  "amountUSD": {
                    "type": "number",
                    "description": "Iznos investicije u USD.",
                    "example": 2000
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transakcija uspešno izvršena.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "txHash": { "type": "string", "example": "0x123abc..." }
                  }
                }
              }
            }
          },
          "500": { "description": "KYC nije verifikovan ili greška pri slanju transakcije." }
        }
      }
    },
    "/users/profile": {
      "get": {
        "summary": "Vraća podatke o prijavljenom korisniku",
        "tags": ["Users"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Podaci o korisniku." },
          "401": { "description": "Autorizacija neuspešna." }
        }
      }
    },
    "/users/kyc": {
      "get": {
        "summary": "Vraća KYC status prijavljenog korisnika",
        "tags": ["KYC"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "KYC podaci.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/KYCStatus" }
              }
            }
          },
          "401": { "description": "Autorizacija neuspešna." }
        }
      }
    },
    "/users/kyc/submit": {
      "post": {
        "summary": "Šalje KYC zahtev sa dokumentom",
        "tags": ["KYC"],
        "description": "Prima multipart/form-data sa ličnim podacima i fotografijom/PDF dokumenta. Postavlja status na 'pending'.",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["fullName", "documentType", "documentNumber", "dateOfBirth", "country", "document"],
                "properties": {
                  "fullName": { "type": "string", "example": "Petar Petrović" },
                  "documentType": { "type": "string", "enum": ["id_card", "passport"] },
                  "documentNumber": { "type": "string", "example": "001234567" },
                  "dateOfBirth": { "type": "string", "example": "1995-06-12" },
                  "country": { "type": "string", "example": "Srbija" },
                  "document": { "type": "string", "format": "binary" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Zahtev primljen.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/KYCStatus" }
              }
            }
          },
          "400": { "description": "Nevalidan unos, prevelik fajl, ili već postoji aktivna prijava." }
        }
      }
    },
    "/admin/analytics": {
      "get": {
        "summary": "Vraća kompletnu analitiku investicija (samo za admina)",
        "tags": ["Admin"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Uspešno dohvaćena analitika." },
          "401": { "description": "Token nije priložen ili nije validan." },
          "403": { "description": "Korisnik nema admin privilegije." }
        }
      }
    },
    "/admin/kyc": {
      "get": {
        "summary": "Lista svih KYC prijava (samo za admina)",
        "tags": ["Admin", "KYC"],
        "description": "Opcioni query parametar 'status' filtrira po statusu (none/pending/verified/rejected).",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "in": "query",
            "name": "status",
            "schema": { "type": "string", "enum": ["none", "pending", "verified", "rejected"] }
          }
        ],
        "responses": {
          "200": {
            "description": "Lista prijava.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/KYCStatus" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/admin/kyc/{userId}/document": {
      "get": {
        "summary": "Preuzima KYC dokument korisnika (samo za admina)",
        "tags": ["Admin", "KYC"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "in": "path", "name": "userId", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Binarni sadržaj dokumenta (PDF/JPG/PNG).",
            "content": {
              "application/octet-stream": { "schema": { "type": "string", "format": "binary" } }
            }
          },
          "404": { "description": "Dokument ne postoji." }
        }
      }
    },
    "/admin/kyc/{userId}/approve": {
      "post": {
        "summary": "Odobrava KYC prijavu (samo za admina)",
        "tags": ["Admin", "KYC"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "in": "path", "name": "userId", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Prijava odobrena.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/KYCStatus" }
              }
            }
          },
          "400": { "description": "Prijava nije u statusu 'pending'." }
        }
      }
    },
    "/admin/kyc/{userId}/reject": {
      "post": {
        "summary": "Odbija KYC prijavu (samo za admina)",
        "tags": ["Admin", "KYC"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "in": "path", "name": "userId", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["reason"],
                "properties": {
                  "reason": { "type": "string", "example": "Dokument nije čitljiv." }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Prijava odbijena.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/KYCStatus" }
              }
            }
          },
          "400": { "description": "Razlog nije naveden ili prijava nije u statusu 'pending'." }
        }
      }
    }
  }
}

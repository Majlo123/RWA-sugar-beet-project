{
  "openapi": "3.0.0",
  "info": {
    "title": "Sugar Beet Token API",
    "version": "1.1.0",
    "description": "API for managing sugar beet investments, users, and the KYC process"
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "KYCStatus": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": ["none", "pending", "verified", "rejected"]
          },
          "fullName": { "type": "string" },
          "documentType": { "type": "string", "enum": ["id_card", "passport"] },
          "documentNumber": { "type": "string" },
          "dateOfBirth": { "type": "string" },
          "country": { "type": "string" },
          "hasDocument": { "type": "boolean" },
          "submittedAt": { "type": "string", "format": "date-time" },
          "reviewedAt": { "type": "string", "format": "date-time" },
          "rejectionReason": { "type": "string" }
        }
      }
    }
  },
  "security": [
    { "bearerAuth": [] }
  ],
  "servers": [
    { "url": "http://localhost:5000" }
  ],
  "paths": {
    "/auth/register": {
      "post": {
        "summary": "Register a new user",
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": { "type": "string", "example": "investor1" },
                  "password": { "type": "string", "example": "password123" },
                  "ethAddress": { "type": "string", "example": "0x... new account address" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "User registered successfully." },
          "400": { "description": "Username is already taken or input is invalid." }
        }
      }
    },
    "/auth/login": {
      "post": {
        "summary": "Log in an existing user",
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": { "type": "string", "example": "investor1" },
                  "password": { "type": "string", "example": "password123" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Successful login, returns a JWT token." },
          "400": { "description": "Invalid credentials." }
        }
      }
    },
    "/token-price": {
      "get": {
        "summary": "Return the price of a single token in USD",
        "tags": ["Treasury"],
        "description": "Reads the public TOKEN_PRICE_USD constant from the smart contract.",
        "responses": {
          "200": {
            "description": "Successful response with the token price.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "tokenPriceUSD": { "type": "string", "example": "1000" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/record-investment": {
      "post": {
        "summary": "Record a new investment (admin only)",
        "tags": ["Treasury"],
        "description": "Calls the recordInvestment function on the smart contract. The investor must have KYC status 'verified'.",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "investorAddress": {
                    "type": "string",
                    "description": "Investor's Ethereum address.",
                    "example": "0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266"
                  },
                  "amountUSD": {
                    "type": "number",
                    "description": "Investment amount in USD.",
                    "example": 2000
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transaction executed successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "txHash": { "type": "string", "example": "0x123abc..." }
                  }
                }
              }
            }
          },
          "500": { "description": "KYC not verified or error sending the transaction." }
        }
      }
    },
    "/users/profile": {
      "get": {
        "summary": "Return data about the logged-in user",
        "tags": ["Users"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "User data." },
          "401": { "description": "Authorization failed." }
        }
      }
    },
    "/users/kyc": {
      "get": {
        "summary": "Return the KYC status of the logged-in user",
        "tags": ["KYC"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "KYC data.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/KYCStatus" }
              }
            }
          },
          "401": { "description": "Authorization failed." }
        }
      }
    },
    "/users/kyc/submit": {
      "post": {
        "summary": "Submit a KYC request with a document",
        "tags": ["KYC"],
        "description": "Accepts multipart/form-data with personal data and a photo/PDF of the document. Sets status to 'pending'.",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["fullName", "documentType", "documentNumber", "dateOfBirth", "country", "document"],
                "properties": {
                  "fullName": { "type": "string", "example": "John Smith" },
                  "documentType": { "type": "string", "enum": ["id_card", "passport"] },
                  "documentNumber": { "type": "string", "example": "001234567" },
                  "dateOfBirth": { "type": "string", "example": "1995-06-12" },
                  "country": { "type": "string", "example": "Serbia" },
                  "document": { "type": "string", "format": "binary" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Request accepted.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/KYCStatus" }
              }
            }
          },
          "400": { "description": "Invalid input, file too large, or an active submission already exists." }
        }
      }
    },
    "/admin/analytics": {
      "get": {
        "summary": "Return complete investment analytics (admin only)",
        "tags": ["Admin"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Analytics fetched successfully." },
          "401": { "description": "Token not provided or invalid." },
          "403": { "description": "User does not have admin privileges." }
        }
      }
    },
    "/admin/kyc": {
      "get": {
        "summary": "List all KYC submissions (admin only)",
        "tags": ["Admin", "KYC"],
        "description": "Optional 'status' query parameter filters by status (none/pending/verified/rejected).",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "in": "query",
            "name": "status",
            "schema": { "type": "string", "enum": ["none", "pending", "verified", "rejected"] }
          }
        ],
        "responses": {
          "200": {
            "description": "List of submissions.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/KYCStatus" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/admin/kyc/{userId}/document": {
      "get": {
        "summary": "Download a user's KYC document (admin only)",
        "tags": ["Admin", "KYC"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "in": "path", "name": "userId", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Binary content of the document (PDF/JPG/PNG).",
            "content": {
              "application/octet-stream": { "schema": { "type": "string", "format": "binary" } }
            }
          },
          "404": { "description": "Document does not exist." }
        }
      }
    },
    "/admin/kyc/{userId}/approve": {
      "post": {
        "summary": "Approve a KYC submission (admin only)",
        "tags": ["Admin", "KYC"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "in": "path", "name": "userId", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Submission approved.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/KYCStatus" }
              }
            }
          },
          "400": { "description": "Submission is not in 'pending' status." }
        }
      }
    },
    "/admin/kyc/{userId}/reject": {
      "post": {
        "summary": "Reject a KYC submission (admin only)",
        "tags": ["Admin", "KYC"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "in": "path", "name": "userId", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["reason"],
                "properties": {
                  "reason": { "type": "string", "example": "Document is not readable." }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Submission rejected.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/KYCStatus" }
              }
            }
          },
          "400": { "description": "Reason not provided or submission is not in 'pending' status." }
        }
      }
    }
  }
}
